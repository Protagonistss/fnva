# 环境切换工具配置文件示例
# 复制此文件到 ~/.fnva/config.toml (Linux/macOS) 或 %USERPROFILE%\.fnva\config.toml (Windows)

# 当前激活的 Java 环境名称
current_java_env = "jdk17"

# 默认 Java 环境名称（类似 fnm 的默认版本）
default_java_env = "jdk17"
default_cc_env = "glmcc"

# 自定义 Java 扫描路径（用于自动发现已安装的 Java）
custom_java_scan_paths = [
    "/usr/lib/jvm",           # Linux 系统默认 Java 安装路径
    "/Library/Java/JavaVirtualMachines",  # macOS 系统默认 Java 安装路径
    "C:\\Program Files\\Java",  # Windows 系统默认 Java 安装路径
]

# 明确移除的 Java 环境名称（防止重新扫描添加）
removed_java_names = []

# Java 环境配置
[[java_environments]]
name = "jdk17"
java_home = "/usr/lib/jvm/java-17-openjdk"
description = "OpenJDK 17 (Manual)"
source = "manual"

[[java_environments]]
name = "jdk11"
java_home = "/usr/lib/jvm/java-11-openjdk"
description = "OpenJDK 11 (Scanned)"
source = "scanned"

[[java_environments]]
name = "jdk21.0.3"
java_home = "/home/user/.fnva/java-packages/jdk-21.0.3"
description = "Java 21.0.3 (Installed)"
source = "manual"

# LLM 环境配置
[[llm_environments]]
name = "openai-dev"
provider = "openai"
api_key = "${OPENAI_API_KEY}"  # 支持环境变量引用
base_url = "https://api.openai.com/v1"
model = "gpt-4"
temperature = 0.7
max_tokens = 2000
description = "OpenAI 开发环境"

[[llm_environments]]
name = "anthropic-prod"
provider = "anthropic"
api_key = "${ANTHROPIC_API_KEY}"
base_url = "https://api.anthropic.com"
model = "claude-3-opus-20240229"
temperature = 0.8
max_tokens = 4096
description = "Anthropic 生产环境"

[[llm_environments]]
name = "azure-openai"
provider = "azure-openai"
api_key = "${AZURE_OPENAI_API_KEY}"
base_url = "https://your-resource.openai.azure.com"
model = "gpt-4"
description = "Azure OpenAI"

[[llm_environments]]
name = "ollama-local"
provider = "ollama"
base_url = "http://localhost:11434"
model = "llama2"
description = "本地 Ollama 服务"

# CC (Claude Code) 环境配置
[[cc_environments]]
name = "anthropic-cc"
provider = "anthropic"
api_key = "${ANTHROPIC_API_KEY}"
base_url = "https://api.anthropic.com"
sonnet_model = "claude-sonnet-4-5"    # 默认 sonnet 模型
# opus_model = "claude-opus-4-5"     # 可选：opus 专用模型
# haiku_model = "claude-haiku-4-5"   # 可选：haiku 专用模型
description = "Anthropic Claude Code 环境"

[[cc_environments]]
name = "moonshot-cc"
provider = "anthropic"
api_key = "${MOONSHOT_API_KEY}"
base_url = "https://api.moonshot.cn/anthropic"
sonnet_model = "claude-sonnet-4-5"
description = "Moonshot Claude Code 环境"

# 镜像配置（模板化 URL）
# 每个镜像定义 URL 模板，按 priority 排序自动回退
# 可用模板变量: {base_url}, {major}, {tag}, {filename}, {os}, {arch}
[[mirrors.java]]
name = "tsinghua"
priority = 1
enabled = true
base_url = "https://mirrors.tuna.tsinghua.edu.cn/Adoptium"
url_template = "{base_url}/{major}/jdk/{arch}/{os}/{filename}"

[[mirrors.java]]
name = "github"
priority = 2
enabled = true
url_template = "https://github.com/adoptium/temurin{major}-binaries/releases/download/{tag}/{filename}"

# Maven 下载镜像(Maven 是跨平台单包,模板变量用 {version}/{filename})
# 版本列表从 apache archive 动态发现;此处只作下载加速
[[mirrors.maven]]
name = "tsinghua"
priority = 1
enabled = true
base_url = "https://mirrors.tuna.tsinghua.edu.cn/apache/maven/maven-3"
url_template = "{base_url}/{version}/binaries/apache-maven-{version}-bin.tar.gz"

[[mirrors.maven]]
name = "apache-archive"
priority = 2
enabled = true
base_url = "https://archive.apache.org/dist/maven/maven-3"
url_template = "{base_url}/{version}/binaries/apache-maven-{version}-bin.tar.gz"

